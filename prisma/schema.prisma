generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pipeline {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  nodes     PipelineNode[]
  flowItems FlowItem[]

  @@map("sys_pipeline")
}

model PipelineNode {
  id         String   @id @default(cuid())
  pipelineId String   @map("pipeline_id")
  nodeName   String   @map("node_name")
  nodeType   String   @map("node_type")
  order      Int
  isRequired Boolean  @default(true) @map("is_required")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("sys_pipeline_node")
  @@index([pipelineId])
}

model FlowItem {
  id             String   @id @default(cuid())
  name           String
  businessLine   String   @map("business_line")
  application    String
  pipelineId     String   @map("pipeline_id")
  status         Int      @default(0)
  progress       Int      @default(0)
  codeRepository String?  @map("code_repository")
  branch         String?
  creator        String
  devOwner       String?  @map("dev_owner")
  testOwner      String?  @map("test_owner")
  jiraCardId     String?  @map("jira_card_id")
  spaceId        String?  @map("space_id")
  sprintId       String?  @map("sprint_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  pipeline Pipeline      @relation(fields: [pipelineId], references: [id])
  dates    FlowItemDate?
  workers  FlowWorker[]

  @@unique([application, name])
  @@map("flow_item")
  @@index([businessLine])
  @@index([application])
  @@index([status])
  @@index([pipelineId])
}

model FlowWorker {
  id             String    @id @default(cuid())
  flowItemId     String    @map("flow_item_id")
  pipelineNodeId String    @map("pipeline_node_id")
  nodeName       String    @map("node_name")
  nodeType       String    @map("node_type")
  order          Int
  status         Int       @default(0)
  isRequired     Boolean   @default(true) @map("is_required")
  startTime      DateTime? @map("start_time")
  endTime        DateTime? @map("end_time")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  flowItem FlowItem @relation(fields: [flowItemId], references: [id], onDelete: Cascade)

  @@map("flow_worker")
  @@index([flowItemId])
  @@index([status])
}

model FlowItemDate {
  id                 String    @id @default(cuid())
  flowItemId         String    @unique @map("flow_item_id")
  planDevStartTime   DateTime? @map("plan_dev_start_time")
  actualDevStartTime DateTime? @map("actual_dev_start_time")
  planTestStartTime  DateTime? @map("plan_test_start_time")
  actualTestStartTime DateTime? @map("actual_test_start_time")
  planReleaseTime    DateTime? @map("plan_release_time")
  actualReleaseTime  DateTime? @map("actual_release_time")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  flowItem FlowItem @relation(fields: [flowItemId], references: [id], onDelete: Cascade)

  @@map("flow_item_date")
}
